# Copy to ~/.dbt/profiles.yml — never commit the real file.
ipl_dbt:
  target: dev
  outputs:
    dev:
      type: athena
      region_name: ap-south-1
      s3_staging_dir: s3://ipl-athena-results-814871720600/dbt/
      s3_data_dir: s3://ipl-processed-data-814871720600/dbt/
      database: AwsDataCatalog    # Athena catalog name — always this value
      schema: dbt_dev             # Glue database where dbt models are written
      work_group: ipl-workgroup
      aws_profile_name: default   # your local AWS CLI profile

    prod:
      type: athena
      region_name: ap-south-1
      s3_staging_dir: s3://ipl-athena-results-814871720600/dbt/
      s3_data_dir: s3://ipl-processed-data-814871720600/dbt/
      database: AwsDataCatalog    # Athena catalog name — always this value
      schema: dbt_prod            # Glue database where dbt models are written
      work_group: ipl-workgroup
      # prod uses IAM role from GitHub Actions env — no profile needed
